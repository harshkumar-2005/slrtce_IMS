generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "mysql"
}

//
// ENUMS
//

enum Role {
  STUDENT
  TEACHER
  ADMIN
  STAFF
}

enum AdminLevel {
  NORMAL
  SUPER
}

enum OtpType {
  LOGIN
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

enum SubjectType {
  THEORY
  PRACTICAL
  LAB
}

enum SemesterStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

//
// USER (CORE AUTH ENTITY)
//

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String
  phone    String @unique

  role Role @default(STUDENT)

  isActive        Boolean @default(true)
  isEmailVerified Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  refreshTokens  RefreshToken[]
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  adminProfile   AdminProfile?
  staffProfile   StaffProfile?
  otpRecords     Otp[]

  @@index([email])
  @@index([phone])
}

//
// STUDENT PROFILE
//

model StudentProfile {
  id Int @id @default(autoincrement())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  uid    String @unique @db.VarChar(50)
  rollNo String @unique

  branchId           Int
  departmentId       Int
  branchDepartmentId Int
  semesterId         String

  branchDepartment BranchDepartment @relation(fields: [branchDepartmentId], references: [id], onDelete: Cascade)
  branch           Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  department       Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  semester         Semester         @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  section String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  @@index([branchId])
  @@index([departmentId])
  @@index([branchDepartmentId])
}

//
// TEACHER PROFILE
//

model TeacherProfile {
  id Int @id @default(autoincrement())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  departmentId  Int
  designationId Int

  department      Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  designation     Designation      @relation(fields: [designationId], references: [id], onDelete: Cascade)
  teacherSubjects TeacherSubject[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  @@index([departmentId])
  @@index([designationId])
}

//
// ADMIN PROFILE
//

model AdminProfile {
  id Int @id @default(autoincrement())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessLevel AdminLevel @default(NORMAL)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  @@index([userId])
}

//
// STAFF PROFILE
//

model StaffProfile {
  id Int @id @default(autoincrement())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  departmentId Int
  positionId   Int

  department Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  position   StaffPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  @@index([departmentId])
  @@index([positionId])
}

//
// AUTH - REFRESH TOKENS
//

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(512)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Security enhancements
  isRevoked       Boolean @default(false)
  userAgent       String?
  ipAddress       String?
  replacedByToken String? @db.VarChar(512)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// 
// academic year
// 

model AcademicYear {
  id        String   @id @default(uuid())
  name      String // "2025-2026"
  startDate DateTime
  endDate   DateTime

  semesters Semester[]
}

// 
// Semester table
// 

model Semester {
  id String @id @default(uuid())

  name   String // "Sem 1"
  number Int // 1,2,3
  status SemesterStatus @default(UPCOMING)

  startDate DateTime
  endDate   DateTime

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  branchDepartmentId Int
  branchDepartment   BranchDepartment @relation(fields: [branchDepartmentId], references: [id], onDelete: Cascade)

  isActive Boolean @default(false)

  createdAt DateTime @default(now())

  studentProfiles StudentProfile[]
  subjects        Subject[]
  teacherSubjects TeacherSubject[]
}

//
// Branch table 
//

model Branch {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  code      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  students          StudentProfile[]
  branchDepartments BranchDepartment[]
}

//
// Department table
//

model Department {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  code      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  students          StudentProfile[]
  teachers          TeacherProfile[]
  staff             StaffProfile[]
  branchDepartments BranchDepartment[]
}

//
// BranchDepartment mapping table 
//

model BranchDepartment {
  id Int @id @default(autoincrement())

  branchId     Int
  departmentId Int
  isActive     Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  department      Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  studentProfiles StudentProfile[]
  subjects        Subject[]
  semesters       Semester[]

  @@unique([branchId, departmentId])
}

//
// Subject table
//

model Subject {
  id Int @id @default(autoincrement())

  name String
  code String

  branchDepartmentId Int
  semesterId         String

  credits Int

  type SubjectType @default(THEORY)

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  branchDepartment BranchDepartment @relation(fields: [branchDepartmentId], references: [id], onDelete: Cascade)
  semester         Semester         @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  teacherSubjects  TeacherSubject[]

  @@unique([code, branchDepartmentId, semesterId])
  @@index([semesterId])
}

// 
// Teacher Subject mapping
// 

model TeacherSubject {
  id Int @id @default(autoincrement())

  teacherId  Int
  subjectId  Int
  semesterId String
  section    String?

  assignedAt DateTime @default(now())

  teacher  TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject  Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  semester Semester       @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  @@unique([teacherId, subjectId, semesterId, section])
}

//
// Designation table
//

model Designation {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  code      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  teachers TeacherProfile[]
}

//
// staff position table
//

model StaffPosition {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  code      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  staff StaffProfile[]
}

//
// OTP (One-Time Password) for verification
//

model Otp {
  id Int @id @default(autoincrement())

  email  String
  userId String?

  otp String // hashed OTP value for security.

  type OtpType

  isUsed Boolean @default(false)

  expiresAt DateTime
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([userId])
  @@index([email, type])
}
