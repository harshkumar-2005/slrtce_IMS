generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "mysql"
}

//
// ENUMS
//

enum Role {
  ADMIN
  TEACHER
  STUDENT
  STAFF
}

enum Branch {
  CSE
  ECS
  ECE
  MECH
  CIVIL
  EEE
}

enum Department {
  COMPUTER_SCIENCE
  ELECTRONICS
  MECHANICAL
  CIVIL
  ELECTRICAL
  SCIENCE
  ADMINISTRATION
}

enum Designation {
  PROFESSOR
  ASSISTANT_PROFESSOR
  HOD
  LECTURER
}

enum AdminLevel {
  NORMAL
  SUPER
}

enum StaffPosition {
  CLERK
  LAB_ASSISTANT
  LIBRARIAN
  TECHNICIAN
}

//
// USER (CORE AUTH ENTITY)
//

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String
  phone    String @unique

  role Role @default(STUDENT)

  isActive        Boolean @default(true)
  isEmailVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  refreshTokens  RefreshToken[]
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  adminProfile   AdminProfile?
  staffProfile   StaffProfile?

  @@index([email])
}

//
// STUDENT PROFILE
//

model StudentProfile {
  id Int @id @default(autoincrement())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  uid        String     @unique @db.VarChar(50)
  rollNo     String     @unique
  branch     Branch
  department Department
  semester   Int
  year       Int
  section    String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([rollNo])
}

//
// TEACHER PROFILE
//

model TeacherProfile {
  id Int @id @default(autoincrement())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  department  Department
  designation Designation

  createdAt DateTime @default(now())

  @@index([userId])
}

//
// ADMIN PROFILE
//

model AdminProfile {
  id Int @id @default(autoincrement())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessLevel AdminLevel @default(NORMAL)

  createdAt DateTime @default(now())

  @@index([userId])
}

//
// STAFF PROFILE
//

model StaffProfile {
  id Int @id @default(autoincrement())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  department Department
  position   StaffPosition

  createdAt DateTime @default(now())

  @@index([userId])
}

//
// AUTH - REFRESH TOKENS
//

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(512)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Security enhancements
  isRevoked       Boolean @default(false)
  userAgent       String?
  ipAddress       String?
  replacedByToken String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}
